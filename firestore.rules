rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isContractor() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'contractor';
    }

    // Users Collection
    match /users/{userId} {
      // Anyone can read basic profiles, but only owners/admins can edit
      allow read: if isAuthenticated();
      // Only trigger on create during signup from client side or admin
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // Issues Collection
    match /issues/{issueId} {
      // Anyone can view issues
      allow read: if true;
      
      // Any authenticated user can create an issue
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      
      // Updates depend on role and status
      allow update: if isAuthenticated() && (
        isAdmin() || 
        // Contractor resolving issue
        (isContractor() && request.resource.data.status == 'resolved_pending' && request.resource.data.proof_image_url != null) ||
        // User verifying resolution
        (isOwner(resource.data.user_id) && request.resource.data.status == 'resolved') ||
        // User adding upvote
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvote_count', 'upvoted_by']))
      );
      
      allow delete: if isAdmin();
    }

    // Notifications Collection
    match /notifications/{notificationId} {
      // Users can only read and update their own notifications
      allow read, update: if isAuthenticated() && (
        resource.data.user_id == request.auth.uid || 
        (isAdmin() && resource.data.recipient_role == 'admin')
      );
      // System generated only (via Cloud Functions), except admins
      allow create, delete: if isAdmin();
    }
  }
}
